{
  "manifest_version": 3,
  "name": "抖音IP属地助手",
  "version": "1.0.0",
  "description": "在抖音网页版视频页面显示IP省份和城市信息",
  "author": "Hanako",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "抖音IP属地助手"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.douyin.com/*",
        "*://douyin.com/*"
      ],
      "js": ["content-script.js"],
      "css": ["styles.css"],
      "run_at": "document_start"
    }
  ],
  "host_permissions": [
    "*://*.douyin.com/*",
    "*://douyin.com/*",
    "*://*.iesdouyin.com/*"
  ],
  "permissions": [
    "storage"
  ],
  "web_accessible_resources": [
    {
      "resources": ["styles.css"],
      "matches": ["*://*.douyin.com/*"]
    }
  ]
}
